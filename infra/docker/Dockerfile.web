# Web image. Builds the Next.js app and serves it with `next start`.
#
# Single-stage on purpose: it's the most legible form for a learning repo. A
# production optimization would use Next's `output: "standalone"` and a slim
# runtime stage to shrink the image; noted, not done.

FROM node:22-slim

WORKDIR /app
# Install deps from the committed lockfile first (cached unless deps change).
COPY apps/web/package.json apps/web/package-lock.json ./
RUN npm ci

# Then the app source (incl. the generated lib/types.ts, which is committed — the
# build needs no backend running).
COPY apps/web/ ./

# NEXT_PUBLIC_* is inlined into the client bundle at BUILD time. The browser runs
# on the host, so it reaches the API at the host-published port, not the compose
# service name — hence localhost:8000, overridable per deployment via build arg.
ARG NEXT_PUBLIC_API_URL=http://localhost:8000
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
RUN npm run build

EXPOSE 3000
# -H 0.0.0.0 so the mapped host port reaches the server inside the container.
CMD ["npx", "next", "start", "-H", "0.0.0.0", "-p", "3000"]
