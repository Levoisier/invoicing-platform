# Copy to .env before `make up` / `make dev`. The compose file and the API host
# both read these. Keep real secrets out of git — this file is the template only.

# --- Database -------------------------------------------------------------
# Postgres connection. The compose `db` service is seeded from POSTGRES_* and the
# API connects with DATABASE_URL. They must agree on user/password/db name.
POSTGRES_USER=invoicing
POSTGRES_PASSWORD=invoicing
POSTGRES_DB=invoicing
# Host name `db` is the compose service; for local-without-compose use localhost.
DATABASE_URL=postgresql+psycopg://invoicing:invoicing@db:5432/invoicing

# --- Auth -----------------------------------------------------------------
# JWT signing secret for nucleus.api auth. Override with a real random value in
# any deployment you care about.
JWT_SECRET=dev-only-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- Web ------------------------------------------------------------------
# Where the Next.js app reaches the API from the browser.
NEXT_PUBLIC_API_URL=http://localhost:8000
